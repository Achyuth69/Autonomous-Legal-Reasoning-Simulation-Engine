# Application
APP_NAME="Autonomous Legal Reasoning Engine"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# API
API_V1_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (SQLite - no setup required, just a file)
DATABASE_URL=sqlite+aiosqlite:///./data/legal_reasoning.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis (optional - not required for basic functionality)
REDIS_URL=redis://localhost:6379/0

# Google Gemini (FREE - get key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=4000

# Groq (Multi-Model Debate)
GROQ_API_KEY=your-groq-api-key-here
GROQ_DEBATE_ROUNDS=3
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=legal_documents

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB
UPLOAD_DIR=./data/uploads

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Security
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
